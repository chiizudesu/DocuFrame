{
  "name": "docuframe",
  "private": true,
  "version": "1.0.0",
  "author": "Edward John Matias <edwardjohncpa@gmail.com>",
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "clean-electron": "node -e \"const fs=require('fs');const path=require('path');const dir='dist-electron';if(fs.existsSync(dir)){fs.readdirSync(dir).forEach(f=>{if(f.match(/^(main|index)-[A-Za-z0-9-]+\\.js$/)){fs.unlinkSync(path.join(dir,f));console.log('Deleted:',f);}});console.log('Cleaned old electron build artifacts');}\"",
    "dev": "cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true vite",
    "build": "tsc --noEmit && vite build",
    "build-safe": "tsc --noEmit --skipLibCheck && vite build",
    "build-no-check": "vite build",
    "prod": "npm run build-no-check && cross-env NODE_ENV=production electron .",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production electron .",
    "setup": "node setup.js",
    "validate-setup": "node setup.js --validate",
    "dev-all": "concurrently \"npm run dev\"",
    "profiler": "cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=true VITE_REACT_DEVTOOLS=true concurrently -n devtools,vite -c cyan,magenta \"react-devtools\" \"wait-on -t 120000 tcp:127.0.0.1:8097 && vite\"",
    "setup-all": "npm run setup && echo \"Setup complete! Run: npm run dev\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "rebuild-native": "node rebuild-uiohook.js",
    "electron-pack": "electron-builder",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist-win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "dist-win-unsigned": "npm run build-no-check && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "publish-github": "npm run build-no-check && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish always",
    "make": "electron-forge make",
    "publish": "electron-forge publish"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@chakra-ui/react": "^3.0.0",
    "@emotion/react": "^11.14.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@tanstack/react-virtual": "^3.0.1",
    "@types/chokidar": "^1.7.5",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.0",
    "@types/sortablejs": "^1.15.9",
    "adm-zip": "^0.5.16",
    "chokidar": "^4.0.3",
    "csv-parse": "^5.6.0",
    "docx": "^9.5.1",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "get-windows": "^9.2.3",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.513.0",
    "mailparser": "^3.9.1",
    "mammoth": "^1.12.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdf2json": "^3.1.6",
    "pdfjs-dist": "^5.4.54",
    "react": "^18.2.0",
    "react-devtools": "^7.0.1",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sortablejs": "^1.15.7",
    "uiohook-napi": "^1.5.4",
    "use-context-selector": "^2.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/publisher-github": "^7.8.1",
    "@electron/rebuild": "^4.0.2",
    "@types/adm-zip": "^0.5.7",
    "@types/mailparser": "^3.4.6",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^7.6.0",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^26.0.12",
    "electron-notarize": "^1.2.2",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.edwardmatias.docuframe",
    "productName": "DocuFrame",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "asarUnpack": [
      "public/**/*"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DocuFrame",
      "uninstallDisplayName": "DocuFrame",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "chiizudesu",
        "repo": "DocuFrame"
      }
    ]
  }
}
