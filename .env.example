# DocuFrame Server - Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Required: Session secret for OAuth token storage (use a long random string)
SESSION_SECRET=

# Xero OAuth (required for Xero integration)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:5173/oauth/callback.html

# Server
PORT=3001

# Production only
NODE_ENV=development
FRONTEND_URL=
